AWS_SDK_LOG_LEVEL=warn
AWS_REGION=eu-north-1
NODE_ENV=local
# Must match the browser origin (Vite default is http://localhost:5173, not https)
# CORS_ORIGIN=http://localhost:5173
# npm test sets APP_SECRETS_ENABLED=false; use the same locally if .env points APP_SECRET_ID at AWS but you run offline
# APP_SECRETS_ENABLED=false
SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
DYNAMODB_TABLE_NAME=math-history-ddb-local
# Host machine → docker-compose `dynamodb` port 8000
DYNAMODB_ENDPOINT=http://127.0.0.1:8000
# If serverless-offline (or Lambda) runs inside Docker on the compose network, use:
# DYNAMODB_ENDPOINT=http://dynamodb:8000
# Used for presigned PUT (POST /api/upload/presign) and deletes
S3_DATA_BUCKET=math-history-server-data-local
# MinIO from docker-compose (`minio` + `s3-init`); omit in real AWS
# S3_ENDPOINT=http://127.0.0.1:9000
# AWS_ACCESS_KEY_ID=local
# AWS_SECRET_ACCESS_KEY=locallocal
JWT_SECRET=dev_secret
JWT_EXPIRES_IN=8h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
TRUST_API_GATEWAY_AUTH=false
