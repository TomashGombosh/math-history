# Copy to `.env` in this directory (`server/.env`), not the repo root.
# Local dev: from `server/` run `npm run dev` (loads `.env` via scripts/run-with-env.cjs on all platforms).
# Windows: save as `.env` only (not `.env.txt`); `npm run dev` works from PowerShell/cmd — no `export` needed.
AWS_REGION=eu-north-1
NODE_ENV=local
# Optional: canonical public origin for sitemap <loc> (no trailing slash). If unset, uses Host / X-Forwarded-* from the request.
# SITE_URL=https://www.example.com
# Public base URL for teacher image URLs returned by POST /api/upload/presign (same host as S3/CloudFront for `teachers/*` keys). No trailing slash.
# TEACHER_IMAGE_CDN_BASE=https://assets-math-stage.example.com
# Must match the browser origin (Vite default is http://localhost:5173, not https)
# CORS_ORIGIN=http://localhost:5173
SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
DYNAMODB_TABLE_NAME=math-history-ddb-local
# Host machine → docker-compose `dynamodb` port 8000
DYNAMODB_ENDPOINT=http://127.0.0.1:8000
# If serverless-offline (or Lambda) runs inside Docker on the compose network, use:
# DYNAMODB_ENDPOINT=http://dynamodb:8000
# Used for presigned PUT (POST /api/upload/presign) and deletes
S3_DATA_BUCKET=math-history-server-data-local
# MinIO from docker-compose (`minio` + `s3-init`); omit in real AWS
# S3_ENDPOINT=http://127.0.0.1:9000
# AWS_ACCESS_KEY_ID=local
# AWS_SECRET_ACCESS_KEY=locallocal
# Serverless HTTP API JWT authorizer (required for deploy; optional for sls offline — serverless.yml has local placeholders).
# When testing admin routes locally with real Cognito, set these to match client/.env.example:
# COGNITO_JWT_ISSUER=https://cognito-idp.<region>.amazonaws.com/<userPoolId>
# COGNITO_JWT_AUDIENCE=<app client id>
#
# Lambda `admin-auth` expects JWT claims: cognito:groups contains "admin" or role === "admin".
