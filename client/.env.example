# Serverless HTTP API (serverless-offline local or deployed stage URL)
VITE_API_URL=http://localhost:3000

# Public site origin for SEO canonicals (no trailing slash)
# VITE_SITE_URL=https://your-cloudfront-alias.example.com

# --- Amazon Cognito (admin login, SRP in browser via Amplify) ---
#
# Must match server deploy: COGNITO_JWT_ISSUER and COGNITO_JWT_AUDIENCE
#   Issuer:  https://cognito-idp.<region>.amazonaws.com/<userPoolId>
#   Audience: app client id (same as VITE_COGNITO_USER_POOL_CLIENT_ID)
#
# Region: encoded in the pool id prefix (e.g. eu-north-1_…). No separate VITE region var required.
#
# App client (Terraform `app-cognito`): no secret; explicit auth flows SRP + refresh.
# User pool: email as username; admins must be in Cognito group `admin` (see server `admin-auth.ts`).
#
VITE_COGNITO_USER_POOL_ID=eu-north-1_xxxxxxxx
VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Hosted UI / OAuth: not used by the current app. If you switch to Hosted UI later, configure
# in the Cognito console: hosted UI domain, callback/logout URLs, OAuth scopes — and add any
# Vite env vars your redirect flow needs (Amplify `oauth` config).
